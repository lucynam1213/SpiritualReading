# Copy this file to `.env` and fill in your values.
# `.env` is gitignored so your key never lands in the repo.

# ── Required ─────────────────────────────────────────────────
# Your ElevenLabs API key (starts with `xi-`).
# Get one from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ── Optional ─────────────────────────────────────────────────
# Override the voice ID used by scripts/generate-audio.js.
# If unset, the script falls back to the runtime default in script.js
# (TTS_API_DEFAULTS.voiceId — currently "Bella": EXAVITQu4vr4xnSDxMaL).
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
